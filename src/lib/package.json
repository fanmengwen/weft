{
    "name": "@weft/core",
    "version": "0.1.0",
    "description": "Core parsers, types, and brand utilities for the Weft diagramming canvas.",
    "type": "module",
    "main": "./dist/weft-core.cjs.js",
    "module": "./dist/weft-core.es.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/weft-core.es.js",
            "require": "./dist/weft-core.cjs.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "keywords": [
        "diagram",
        "flowchart",
        "mermaid",
        "react-flow",
        "white-label",
        "diagramming",
        "dsl",
        "parser",
        "brand",
        "weft"
    ],
    "author": "fanmengwen",
    "license": "MIT",
    "homepage": "https://fanmengwen.com",
    "peerDependencies": {
        "react": ">=18",
        "react-dom": ">=18",
        "reactflow": ">=11"
    },
    "peerDependenciesMeta": {
        "reactflow": {
            "optional": true
        }
    },
    "sideEffects": false,
    "engines": {
        "node": ">=18"
    }
}
